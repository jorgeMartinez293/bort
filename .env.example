# Reddit public JSON API — no credentials needed
# Optional: customize the User-Agent string
REDDIT_USER_AGENT=bort/0.1

# Gemini API key — used by the script expander (free tier: gemini-flash, 15 RPM, 1M tok/day)
# (optional) If unset, the expander falls back to keyword-based templates instead
GEMINI_API_KEY=

# Paths (override for prod to point at NVMe/HDD mount points)
DB_PATH=/data/db/bort.db
MEDIA_PATH=/media
REDIS_URL=redis://redis:6379/0

# Video encoder: libx264 (dev/Mac) or h264_v4l2m2m (RPi5)
VIDEO_ENCODER=libx264

# Background music directory (mp3/wav files). Leave dir empty or unset to disable.
MUSIC_PATH=/media/music
MUSIC_VOLUME=0.25

# Piper TTS model path
PIPER_MODEL_PATH=/media/tts_models/en_US-ryan-medium.onnx

# Piper speech rate: >1.0 = slower, <1.0 = faster (default 1.2 = 20% slower)
PIPER_LENGTH_SCALE=1.2

# YouTube Data API v3 — OAuth2 credentials (Desktop App)
# 1. Create project at https://console.cloud.google.com
# 2. Enable YouTube Data API v3
# 3. Create OAuth 2.0 Client ID (Desktop App) and copy client_id + client_secret
# 4. Run: python scripts/youtube_auth.py  → paste the printed YOUTUBE_TOKEN_JSON here
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_TOKEN_JSON=
