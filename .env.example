# Reddit public JSON API — no credentials needed
# Optional: customize the User-Agent string
REDDIT_USER_AGENT=bort/0.1

# Paths (override for prod to point at NVMe/HDD mount points)
DB_PATH=/data/db/bort.db
MEDIA_PATH=/media
REDIS_URL=redis://redis:6379/0

# Video encoder: libx264 (dev/Mac) or h264_v4l2m2m (RPi5)
VIDEO_ENCODER=libx264

# Piper TTS model path
PIPER_MODEL_PATH=/media/tts_models/en_US-lessac-medium.onnx
